{
  "name": "@thednp/shorty",
  "version": "2.0.12",
  "description": "TypeScript shorties for the web",
  "author": "thednp",
  "homepage": "https://github.com/thednp/shorty",
  "license": "MIT",
  "browser": "./dist/index.umd.js",
  "source": "./src/index.ts",
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "pre-test": "pnpm clean-coverage",
    "badges": "npx -p dependency-version-badge update-badge typescript vitest vite",
    "prepublishOnly": "pnpm update --latest && pnpm lint && pnpm format && pnpm build",
    "test": "pnpm pre-test && vitest --browser.headless",
    "test-ui": "pnpm pre-test && vitest --browser --ui",
    "clean-coverage": "rm -rf coverage .nyc_output",
    "format": "deno fmt src",
    "lint": "pnpm lint:ts",
    "lint:ts": "deno lint src",
    "fix:ts": "deno lint src --fix",
    "check:ts": "tsc -noEmit",
    "build": "tsdown",
    "build_": "vite build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thednp/shorty.git"
  },
  "keywords": [
    "shorty",
    "javascript",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/thednp/shorty/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-strip-comments": "^0.0.9",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@8.6.12",
  "engines": {
    "node": ">=16",
    "pnpm": ">=8.6.0"
  }
}
